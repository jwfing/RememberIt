# Database (cloud PostgreSQL with pgvector)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/rememberit

# LLM - OpenRouter
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# Embedding
EMBEDDING_MODEL_NAME=paraphrase-multilingual-mpnet-base-v2
EMBEDDING_CACHE_DIR=./models

# Server
API_HOST=0.0.0.0
API_PORT=6789

# Retrieval tuning
SCORE_WEIGHT_SEMANTIC=0.5
SCORE_WEIGHT_IMPORTANCE=0.3
SCORE_WEIGHT_TIME=0.2
TIME_DECAY_LAMBDA=0.1
MAX_RESULTS_PER_QUERY=5
MAX_TOKENS_PER_QUERY=2000

# Cost control
MAX_SEGMENTS_PER_CONVERSATION=3
